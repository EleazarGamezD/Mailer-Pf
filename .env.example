## Configuration for Mailer-Pf application
NODE_ENV="" 				# Provide a value for NODE_ENV
APP_PORT="" 				# Provide a value for APP_PORT
API_BASE_URL="" 				# Provide a value for API_BASE_URL
CORS_ORIGIN="" 				# Provide a value for CORS_ORIGIN
AUTO_TRANSLATE_TO_ENGLISH="" 				# Provide a value for AUTO_TRANSLATE_TO_ENGLISH

## Admin API key (used for securing admin routes, should be a long random string in production)
ADMIN_API_KEY="" 				# Provide a value for ADMIN_API_KEY

## JWT configuration
JWT_SECRET="" 				# Provide a value for JWT_SECRET
JWT_EXPIRES_IN="" 				# Provide a value for JWT_EXPIRES_IN

## Maximum size for JSON payloads
JSON_LIMIT="" 				# Provide a value for JSON_LIMIT

## Mail configuration
FROM="" 				# Provide a value for FROM
TO="" 				# Provide a value for TO
GMAIL_USER="" 				# Provide a value for GMAIL_USER
GMAIL_PASSWORD="" 				# Provide a value for GMAIL_PASSWORD
RECAPTCHA_SECRET_KEY="" 				# Provide a value for RECAPTCHA_SECRET_KEY

## Database configuration
MONGODB_URI="" 				# Provide a value for MONGODB_URI
MONGODB_DB_NAME="" 				# Provide a value for MONGODB_DB_NAME

# Bucket storage configuration
# Allowed values:
# - minio
# - amazon
# - supabase
# - cloudflare
BUCKET_PROVIDER="" 				# Provide a value for BUCKET_PROVIDER

## S3-compatible configuration
## Used when BUCKET_PROVIDER is:
## - minio
## - amazon
## - supabase
##
## Endpoint format by provider:
## - minio: host only
##   example: localhost
## - amazon: host only or AWS S3 host
##   example: s3.us-east-1.amazonaws.com
## - supabase: full endpoint URL
##   example: https://<project-ref>.storage.supabase.co/storage/v1/s3
S3_ENDPOINT="" 				# Provide a value for S3_ENDPOINT
S3_PORT="" 				# Provide a value for S3_PORT
S3_USE_SSL="" 				# Provide a value for S3_USE_SSL
S3_ACCESS_KEY_ID="" 				# Provide a value for S3_ACCESS_KEY_ID
S3_SECRET_ACCESS_KEY="" 				# Provide a value for S3_SECRET_ACCESS_KEY
S3_REGION="" 				# Provide a value for S3_REGION
S3_BUCKET="" 				# Provide a value for S3_BUCKET

## Cloudflare R2 configuration
## Used only when BUCKET_PROVIDER="cloudflare"
R2_ACCOUNT_ID="" 				# Provide a value for R2_ACCOUNT_ID
R2_ACCESS_KEY_ID="" 				# Provide a value for R2_ACCESS_KEY_ID
R2_SECRET_ACCESS_KEY="" 				# Provide a value for R2_SECRET_ACCESS_KEY
R2_BUCKET="" 				# Provide a value for R2_BUCKET